<Window x:Class="PQC_Vault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Q-Vault Provisioner" Height="600" Width="1000"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        FontFamily="Segoe UI" Loaded="Window_Loaded" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Gradients & Colors -->
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00FFCC" Offset="0"/>
            <GradientStop Color="#0088FF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
            <Setter Property="Foreground" Value="#050505"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="1.0"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="150" CenterY="25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#1A1A1E"/>
                                <Setter Property="Foreground" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,25,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Window Control Button Styles -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButton" BasedOn="{StaticResource WindowControlButton}" TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF3333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DropShadows -->
        <DropShadowEffect x:Key="NeonGlow" Color="#00FFCC" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
        <DropShadowEffect x:Key="ButtonGlow" Color="#0088FF" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        <DropShadowEffect x:Key="PanelShadow" Color="Black" BlurRadius="30" ShadowDepth="10" Opacity="0.7"/>
        <DropShadowEffect x:Key="WarningGlow" Color="#FF8800" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>

        <!-- Tab Style -->
        <Style x:Key="DarkTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="#888899"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent" Padding="20,10" Margin="0,0,5,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="#00FFCC"/>
                                <Setter Property="Foreground" Value="#00FFCC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>

        <!-- Pulse Animation for Status Dot -->
        <Storyboard x:Key="PulseAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Opacity)" From="1.0" To="0.2" Duration="0:0:1" AutoReverse="True"/>
        </Storyboard>

        <!-- Dark ComboBox Style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#16161C"/>
            <Setter Property="BorderBrush" Value="#2A2A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="BgBorder" Background="#16161C" BorderBrush="#2A2A33" BorderThickness="1" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" Background="Transparent">
                                                    <Path x:Name="Arrow" Fill="#AAAAAA" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 5 5 L 10 0 Z"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#00FFCC"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#00FFCC"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="15,0,40,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#111115" BorderThickness="1" BorderBrush="#2A2A33" CornerRadius="8" Margin="0,4,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.8"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="6" Margin="0,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#1A1A24"/>
                                <Setter Property="Foreground" Value="#00FFCC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#0088FF"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="#0B0B0E" BorderBrush="#1C1C24" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- CUSTOM TITLE BAR -->
            <Grid Grid.Row="0" Background="#121217" Panel.ZIndex="10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentGradient}" Margin="0,0,8,0"/>
                    <TextBlock Text="Q-Vault Secure Provisioner" Foreground="#888890" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="—" Width="45" Style="{StaticResource WindowControlButton}" Click="MinimizeBtn_Click"/>
                    <Button Content="✕" Width="45" Style="{StaticResource CloseButton}" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>

            <!-- MAIN CONTENT -->
            <Grid x:Name="MainUI" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE (Status & Info) -->
                <Border Grid.Column="0" Background="#111115" BorderBrush="#18181E" BorderThickness="0,0,2,0">
                    <Grid Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <StackPanel Grid.Row="0" Margin="0,20,0,40" HorizontalAlignment="Center">
                            <TextBlock Text="Q-VAULT" Foreground="{StaticResource AccentGradient}" FontSize="48" FontWeight="Black" FontFamily="Segoe UI Black" HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <StaticResource ResourceKey="NeonGlow"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="P R O V I S I O N E R" Foreground="#555566" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Status Card -->
                        <Border Grid.Row="1" Background="#16161B" CornerRadius="12" Padding="20" Effect="{StaticResource PanelShadow}" BorderBrush="#22222A" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="HARDWARE TOKEN" Foreground="#777788" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                    <Ellipse x:Name="StatusDot" Width="16" Height="16" Fill="#FF3333" Margin="0,0,15,0" VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#FF3333" BlurRadius="15" ShadowDepth="0"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock x:Name="KeyStatusText" Text="Disconnected" Foreground="#FF3333" FontSize="18" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="RefreshBtn" Content="RE-SCAN NOW" Height="45" Style="{StaticResource ModernButton}" Click="RefreshBtn_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Helper Text -->
                        <TextBlock Grid.Row="2" Text="Insert the Q-Vault ESP32 Hardware Token into a USB port to activate provisioning mode. The system automatically scans every second."
                                   Foreground="#444455" FontSize="13" TextWrapping="Wrap" Margin="10,35,10,0" TextAlignment="Center" LineHeight="20"/>

                        <!-- Developer Simulate Toggle -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Opacity="0.5">
                            <CheckBox x:Name="ChkSimulate" Content="Developer: Simulate Token" Foreground="#888899" FontSize="12" Checked="ChkSimulate_Changed" Unchecked="ChkSimulate_Changed" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT SIDE — Unified Provisioning Panel -->
                <Grid Grid.Column="1" x:Name="SetupContainer" IsEnabled="False" Opacity="0.2">
                    <Grid Margin="40,30,40,30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" Text="VAULT SETUP" Foreground="#FFFFFF" FontSize="26" FontWeight="Black" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Text="Select a drive, set a password, and provision the hardware key — all in one step." 
                                   Foreground="#555566" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,30" LineHeight="20"/>

                        <!-- STEP 1: Drive Selection -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,25">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="1." Foreground="#00FFCC" FontSize="13" FontWeight="Black" Margin="0,0,6,0"/>
                                <TextBlock Text="SELECT TARGET DRIVE" Foreground="#00FFCC" FontSize="13" FontWeight="Bold"/>
                                <!-- Status badge shown after selection -->
                                <Border x:Name="DriveStatusBadge" CornerRadius="6" Padding="8,3" Margin="12,0,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="DriveStatusBadgeText" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <ComboBox x:Name="DrivesComboBox" Height="48" FontSize="15" Style="{StaticResource DarkComboBox}" 
                                      VerticalContentAlignment="Center" SelectionChanged="DrivesComboBox_SelectionChanged">
                                <ComboBox.Effect><StaticResource ResourceKey="PanelShadow"/></ComboBox.Effect>
                            </ComboBox>
                            <!-- Drive info line -->
                            <TextBlock x:Name="DriveInfoText" Text="" Foreground="#556677" FontSize="12" Margin="4,7,0,0" Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- STEP 2: Password -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="2." Foreground="#00FFCC" FontSize="13" FontWeight="Black" Margin="0,0,6,0"/>
                                <TextBlock Text="VAULT PASSWORD" Foreground="#00FFCC" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <RadioButton x:Name="RbManual" Content="Enter Manually" IsChecked="True" Checked="PasswordMode_Changed" Unchecked="PasswordMode_Changed"/>
                                <RadioButton x:Name="RbAuto" Content="Auto-Generate Seed (Recommended)" Checked="PasswordMode_Changed" Unchecked="PasswordMode_Changed" Foreground="#00FFCC"/>
                                <RadioButton x:Name="RbRecover" Content="Recover from Seed" Checked="PasswordMode_Changed" Unchecked="PasswordMode_Changed" Foreground="#FFCC00"/>
                            </StackPanel>
                            <Border x:Name="ManualPasswordBorder" Background="#16161C" CornerRadius="10" BorderBrush="#2A2A33" BorderThickness="1" Effect="{StaticResource PanelShadow}">
                                <PasswordBox x:Name="VaultPasswordBox" Height="52" FontSize="22" Background="Transparent" Foreground="White" BorderThickness="0" Padding="20,14" PasswordChar="•"/>
                            </Border>
                            <Border x:Name="AutoPasswordBorder" Background="#262600" CornerRadius="10" BorderBrush="#999900" BorderThickness="1" Padding="16" Visibility="Collapsed" Effect="{StaticResource PanelShadow}">
                                <StackPanel>
                                    <TextBlock Text="⚠ SECURE SEED GENERATION" Foreground="#FFCC00" FontSize="13" FontWeight="ExtraBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="A new 12-word recovery seed will be generated. The Vault Password is deterministically derived from this seed. You MUST save the recovery file containing your 12 words." 
                                               Foreground="#FFFFCC" TextWrapping="Wrap" FontSize="12" LineHeight="19" Opacity="0.9"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="SeedRecoverBorder" Background="#16161C" CornerRadius="10" BorderBrush="#2A2A33" BorderThickness="1" Padding="16" Visibility="Collapsed" Effect="{StaticResource PanelShadow}">
                                <StackPanel>
                                    <TextBlock Text="ENTER YOUR 12-WORD SEED" Foreground="#FFCC00" FontSize="13" FontWeight="ExtraBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="SeedInputBox" Height="60" FontSize="16" Background="Transparent" Foreground="White" BorderThickness="0" Padding="5" TextWrapping="Wrap" AcceptsReturn="True" SpellCheck.IsEnabled="False"/>
                                    <TextBlock Text="We will derive your exact 32-character BitLocker password from this seed and provision the hardware key." 
                                               Foreground="#888899" TextWrapping="Wrap" FontSize="11" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Progress Panel (shown during encryption phase) -->
                        <Border Grid.Row="4" x:Name="EncryptProgressPanel" Visibility="Collapsed" 
                                Background="#16161B" CornerRadius="10" BorderBrush="#22222A" BorderThickness="1" Padding="18,14" Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="ENCRYPTING DRIVE" Foreground="#777788" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="EncryptStatusText" Text="Starting..." Foreground="#00FFCC" FontSize="12" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ProgressBar x:Name="EncryptProgressBar" Height="8" Minimum="0" Maximum="100" Value="0"
                                             Foreground="#00FFCC" Background="#1A1A22" BorderThickness="0" Margin="0,0,0,8"/>
                                <TextBlock x:Name="EncryptPercentText" Text="0%" Foreground="#888899" FontSize="12" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>

                        <!-- Provision Progress Panel (shown during ESP provisioning phase) -->
                        <Border Grid.Row="4" x:Name="ProvisionProgressPanel" Visibility="Collapsed"
                                Background="#0D1A1F" CornerRadius="10" BorderBrush="#003344" BorderThickness="1" Padding="18,14" Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="PROVISIONING KEY" Foreground="#007799" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ProvisionStatusText" Text="Connecting..." Foreground="#00FFCC" FontSize="12" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ProgressBar x:Name="ProvisionProgressBar" Height="8" IsIndeterminate="True"
                                             Foreground="#00FFCC" Background="#1A1A22" BorderThickness="0"/>
                            </StackPanel>
                        </Border>

                        <!-- Provision Button -->
                        <Button Grid.Row="5" x:Name="SetupButton" Content="PROVISION HARDWARE KEY" Height="62" 
                                VerticalAlignment="Bottom" Style="{StaticResource ModernButton}" Click="SetupButton_Click">
                            <Button.Effect><StaticResource ResourceKey="ButtonGlow"/></Button.Effect>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>

            <!-- WAITING OVERLAY -->
            <Border Grid.Row="1" x:Name="WaitingOverlay" Background="#F208080A" Panel.ZIndex="100">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Waiting for Q-Vault..." Foreground="{StaticResource AccentGradient}" FontSize="36" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock.Effect>
                            <StaticResource ResourceKey="NeonGlow"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Please insert the ESP32 Hardware Token into a USB Port" Foreground="#CCCCCC" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TimeoutText" Text="Timeout in 10s" Foreground="#777788" FontSize="15" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <ProgressBar IsIndeterminate="True" Width="300" Height="6" Margin="0,40,0,0" Foreground="#00FFCC" Background="#1A1A22" BorderThickness="0"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
